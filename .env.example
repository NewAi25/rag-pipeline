# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored so secrets never leave your machine.

# =============================================================================
# Provider selection
# =============================================================================
# Which LLM provider to use. Supported:
#   - gemini  (default, FREE tier available)
#   - openai
PROVIDER=gemini

# ----- Gemini (free tier) -----
# Get a FREE key at https://aistudio.google.com/apikey
# Required when PROVIDER=gemini. Free tier has per-minute & per-day request
# caps; the code retries 429s with exponential backoff (1s, 2s, 4s, 8s).
GEMINI_API_KEY=

# ----- OpenAI (paid) -----
# Required when PROVIDER=openai. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# Model overrides (optional)
# =============================================================================
# Leave blank to use the provider's sensible defaults:
#   PROVIDER=gemini  -> CHAT_MODEL=gemini-2.5-flash,  EMBED_MODEL=gemini-embedding-001
#   PROVIDER=openai  -> CHAT_MODEL=gpt-4o-mini,       EMBED_MODEL=text-embedding-3-small
#
# Both the chat and embedding models must come from the SAME provider — they
# share the configured base_url and API key.
CHAT_MODEL=
EMBED_MODEL=

# =============================================================================
# Chunking knobs (optional)
# =============================================================================
# Target chunk size in tokens. ~500 is a good default for paragraph-sized chunks.
CHUNK_SIZE_TOKENS=500

# Overlap between consecutive chunks. Overlap helps avoid splitting an idea
# in half across two chunks, which would hurt retrieval recall.
CHUNK_OVERLAP_TOKENS=50

# =============================================================================
# Retrieval knobs (optional)
# =============================================================================
# How many chunks to retrieve and feed into the prompt.
TOP_K=4

# Retrieval algorithm:
#   - vector  (default)  Dense embeddings only. Cheap, robust to paraphrase.
#   - hybrid             BM25 (keyword) + vector, fused via Reciprocal Rank
#                        Fusion. Better on rare keywords, identifiers, and
#                        proper nouns. Pulls in the rank-bm25 dependency.
RETRIEVAL_MODE=vector

# =============================================================================
# Storage (optional)
# =============================================================================
# Where to persist the local Chroma vector store on disk.
CHROMA_DIR=./chroma_db
CHROMA_COLLECTION=rag_demo

# Silence Chroma's anonymous usage telemetry (also avoids noisy log lines
# when the bundled posthog client and chromadb versions drift apart).
ANONYMIZED_TELEMETRY=False

